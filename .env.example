# Kopie nach .env und Werte eintragen — .env niemals committen!
# cp .env.example .env   (Linux/macOS)
# copy .env.example .env (Windows)

# --- Chat-Synthese (IonOS, optional) ---
IONOS_TOKEN=
IONOS_BASE_URL=https://openai.inference.de-txl.ionos.com/v1
IONOS_MODEL=openai/gpt-oss-120b

# Explizite Datenschutz-Freigabe: Freitext an Cloud-API (true/false)
CLOUD_SYNTHESIS_APPROVED=false

# --- Ollama (lokal, Pipeline + RAG) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- BigQuery (Tabellen optional überschreiben) ---
# BIGQUERY_TABLE=your-gcp-project.pm_daten.anonymes_pm_backlog
# BIGQUERY_HTML_TABLE=your-gcp-project.pm_daten.html_tickets_rohdaten
# BIGQUERY_FIELD_VISITS_TABLE=your-gcp-project.pm_daten.field_visits_feedback
# BIGQUERY_SALES_TABLE=your-gcp-project.pm_daten.sales_product_penetration

# --- BigQuery Upload (Staging → Validierung → Swap) ---
BQ_USE_STAGING=true
BQ_MIN_ROWS=1
BQ_MAX_ROW_DROP_PCT=0.5

# --- RAG / Chunking (optional) ---
RAG_CHUNKER=semantic
RAG_CHUNK_SIZE=512
RAG_SEMANTIC_THRESHOLD=0.72
RAG_OVERLAP_CONTEXT=0.2
# RAG_SEMANTIC_MODEL=minishlab/potion-base-32M

# --- Hotline HTML-Scraper V1 ---
# HOTLINE_HTML_BEREICHE=riwaGisData,teraWinData,otsBauData
# HOTLINE_HTML_BEREICHE=*   # alle Bereiche (teraWin, otsBau, …)
# HOTLINE_EXCLUDE_ALLGEMEIN=true

# --- Betrieb ---
DEPLOYMENT_MODE=single-user

# --- Öffentliche Demo (GitHub) — synthetische Fixtures aus data/demo/ ---
# DEMO_MODE=true
# USE_DEMO_DATA=1

# --- Graylog (Modul-Nutzung → module_usage.csv) ---
# Basis-URL inkl. Port, z. B. http://graylog.example.com:9100
# GRAYLOG_URL=
# Token als HTTP-Basic-Username; Passwort ist immer „token“ (kein Bearer!)
# GRAYLOG_TOKEN=
# Komma-getrennte Stream-IDs oder -Namen; leer = alle Streams
# GRAYLOG_STREAMS=demo-stream-id,Demo Statistik
# GRAYLOG_DAYS=30
# GRAYLOG_MODULE_FIELD=
# GRAYLOG_USER_FIELD=
# GRAYLOG_VERIFY_SSL=true
